PORT=3000
NODE_ENV=production

# Database — update with your VPS MySQL credentials
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=tyla_shop_mis

# Prisma — must match DB_* above
DATABASE_URL="mysql://root:your_mysql_password@127.0.0.1:3306/tyla_shop_mis"

# JWT — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
