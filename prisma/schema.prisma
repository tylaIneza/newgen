generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Branch {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  location   String?  @db.VarChar(255)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  users              User[]
  products           Product[]
  sales              Sale[]
  expenses           Expense[]
  capital_injections CapitalInjection[]
  savings            Saving[]
  audit_logs         AuditLog[]

  @@map("branches")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  users           User[]
  role_permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  role_permissions RolePermission[]
  user_permissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  role_id       Int
  permission_id Int

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password_hash String    @db.VarChar(255)
  role_id       Int
  branch_id     Int?
  is_active     Boolean   @default(true)
  avatar_url    String?   @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  last_login    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  role             Role             @relation(fields: [role_id], references: [id])
  branch           Branch?          @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  user_permissions UserPermission[]
  products         Product[]        @relation("CreatedByUser")
  sales            Sale[]
  stock_movements  StockMovement[]
  expenses         Expense[]
  audit_logs       AuditLog[]
  granted_permissions UserPermission[] @relation("GrantedByUser")
  expense_edit_requests_submitted ExpenseEditRequest[] @relation("RequestedByUser")
  expense_edit_requests_reviewed  ExpenseEditRequest[] @relation("ReviewedByUser")
  capital_injections CapitalInjection[]

  @@index([branch_id])
  @@map("users")
}

model UserPermission {
  user_id       Int
  permission_id Int
  granted_by    Int
  granted_at    DateTime @default(now())

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  granter    User       @relation("GrantedByUser", fields: [granted_by], references: [id])

  @@id([user_id, permission_id])
  @@map("user_permissions")
}

model Product {
  id                  Int      @id @default(autoincrement())
  name                String   @db.VarChar(200)
  sku                 String?  @db.VarChar(100)
  barcode             String?  @db.VarChar(100)
  quantity            Int      @default(0)
  wholesale_price     Decimal  @default(0) @db.Decimal(12, 2)
  low_stock_threshold Int      @default(5)
  unit                String?  @default("piece") @db.VarChar(50)
  description         String?  @db.Text
  image_url           String?  @db.VarChar(255)
  is_active           Boolean  @default(true)
  branch_id           Int      @default(1)
  created_by          Int?
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  creator         User?           @relation("CreatedByUser", fields: [created_by], references: [id])
  branch          Branch          @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  stock_movements StockMovement[]
  sale_items      SaleItem[]

  @@unique([sku, branch_id])
  @@index([barcode])
  @@index([branch_id])
  @@map("products")
}

model StockMovement {
  id              Int      @id @default(autoincrement())
  product_id      Int
  movement_type   StockMovementType
  quantity        Int
  quantity_before Int
  quantity_after  Int
  reference_type  String?  @db.VarChar(50)
  reference_id    Int?
  notes           String?  @db.Text
  performed_by    Int
  created_at      DateTime @default(now())

  product   Product @relation(fields: [product_id], references: [id])
  performer User    @relation(fields: [performed_by], references: [id])

  @@index([product_id])
  @@index([created_at])
  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

model Sale {
  id             Int           @id @default(autoincrement())
  invoice_number String        @unique @db.VarChar(50)
  seller_id      Int
  branch_id      Int           @default(1)
  customer_name  String?       @db.VarChar(150)
  customer_phone String?       @db.VarChar(20)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total_amount   Decimal       @default(0) @db.Decimal(12, 2)
  payment_method PaymentMethod @default(CASH)
  payment_status PaymentStatus @default(PAID)
  notes          String?       @db.Text
  created_at     DateTime      @default(now())
  updated_at     DateTime      @default(now()) @updatedAt

  seller     User       @relation(fields: [seller_id], references: [id])
  branch     Branch     @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  sale_items SaleItem[]

  @@index([seller_id])
  @@index([branch_id])
  @@index([created_at])
  @@index([invoice_number])
  @@map("sales")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PAID
  PENDING
  REFUNDED
}

model SaleItem {
  id            Int     @id @default(autoincrement())
  sale_id       Int
  product_id    Int
  product_name  String  @db.VarChar(200)
  quantity      Int
  selling_price Decimal @db.Decimal(12, 2)
  cost_price    Decimal @default(0) @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  line_total    Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@index([sale_id])
  @@index([product_id])
  @@map("sale_items")
}

model ExpenseCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(255)
  color       String? @default("#6366f1") @db.VarChar(7)

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(200)
  amount       Decimal  @db.Decimal(12, 2)
  category_id  Int
  branch_id    Int      @default(1)
  expense_date DateTime @db.Date
  description  String?  @db.Text
  receipt_url  String?  @db.VarChar(255)
  created_by   Int
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt

  from_savings Boolean  @default(false)

  category     ExpenseCategory      @relation(fields: [category_id], references: [id])
  branch       Branch               @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  creator      User                 @relation(fields: [created_by], references: [id])
  edit_requests ExpenseEditRequest[]

  @@index([expense_date])
  @@index([category_id])
  @@index([branch_id])
  @@map("expenses")
}

model ExpenseEditRequest {
  id           Int                      @id @default(autoincrement())
  expense_id   Int
  requested_by Int
  proposed     Json
  status       ExpenseEditRequestStatus @default(pending)
  reviewed_by  Int?
  review_note  String?                  @db.Text
  reviewed_at  DateTime?
  created_at   DateTime                 @default(now())

  expense   Expense @relation(fields: [expense_id], references: [id], onDelete: Cascade)
  requester User    @relation("RequestedByUser", fields: [requested_by], references: [id])
  reviewer  User?   @relation("ReviewedByUser", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@index([expense_id])
  @@index([status])
  @@index([created_at])
  @@map("expense_edit_requests")
}

enum ExpenseEditRequestStatus {
  pending
  approved
  rejected
}

model CapitalInjection {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(12, 2)
  description String?  @db.VarChar(255)
  date        DateTime @db.Date
  branch_id   Int      @default(1)
  added_by    Int
  created_at  DateTime @default(now())

  admin  User   @relation(fields: [added_by], references: [id])
  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([branch_id])
  @@map("capital_injections")
}

model Saving {
  id                Int      @id @default(autoincrement())
  amount            Decimal  @db.Decimal(12, 2)
  revenue_today     Decimal  @db.Decimal(12, 2)
  remaining_revenue Decimal  @db.Decimal(12, 2)
  date              DateTime @db.Date
  branch_id         Int      @default(1)
  created_at        DateTime @default(now())

  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@unique([date, branch_id])
  @@index([date])
  @@index([branch_id])
  @@map("savings")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  user_name   String?  @db.VarChar(100)
  branch_id   Int?
  action      String   @db.VarChar(100)
  module      String   @db.VarChar(50)
  entity_type String?  @db.VarChar(50)
  entity_id   Int?
  description String?  @db.Text
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(255)
  created_at  DateTime @default(now())

  user   User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)
  branch Branch? @relation(fields: [branch_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([branch_id])
  @@index([action])
  @@index([module])
  @@index([created_at])
  @@map("audit_logs")
}
